# ── bulk / runtime state - never versioned ──────────────────────────
runtime/
state/*.json
!state/*.seed.json
!state/*.example.json
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
dist/
build/
out/
coverage/
htmlcov/
.coverage
*.egg-info/
node_modules/
.next/
*.tsbuildinfo

# ── SECRETS - local credential files stay out of history ────────────
config/*.local.yaml
config/*.local.yml
config/*.local.json
*.local.yaml
*.local.yml
*.local.json
*token*.json
*credentials*
!config/credentials.example.yaml
*.pem
*.key
*.p12
*.pfx
*.pkcs12
id_rsa*
id_ed25519*
*.keystore
.env
.env.*
!.env.example
!.env.sample

# ── live data / databases / logs ────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.log
*.jsonl
!state/*.example.jsonl
!eval/*.jsonl
*.parquet
*.lock
*heartbeat*.json
*incident*.txt

# ── scratch / local artifacts ───────────────────────────────────────
pytest_stdout.txt
junit*.xml
buckets_*.txt
*.bak
*.orig
*.tmp
*.swp

# ── machine / agent state (also add to .git/info/exclude locally) ───
.claude/
.DS_Store
Thumbs.db
.idea/
.vscode/
